# Private key of deployer wallet (with 0x prefix)
DEPLOYER_PRIVATE_KEY=0x

# Admin address - receives all admin roles (use your main wallet)
ADMIN_ADDRESS=0x

# Fee collector - receives protocol fees
FEE_COLLECTOR=0x

# Protocol fee in basis points (30 = 0.3%)
PROTOCOL_FEE_BPS=30

# Max discount cap for TokenGate in bps (3000 = 30%)
MAX_DISCOUNT_CAP_BPS=3000

# Basescan API key for contract verification
# Get free at: https://basescan.org/myapikey
BASESCAN_API_KEY=
